// env.SINGULARITYENV_NXF_TASK_WORKDIR="/data/scratch/DGE/DUDGE/MOPOPGEN/mlubiatowska/pvacseq_nf/test_expression_run/wdir_tmp"

singularity {
    enabled = true
    runOptions = "--bind /mnt:/mnt --bind /data:/data"
    autoMounts = true
    pullTimeout = 2.h
    cacheDir = '/data/scratch/shared/SINGULARITY-DOWNLOAD/nextflow/.singularity'
}

